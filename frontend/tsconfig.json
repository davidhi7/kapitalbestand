{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "strict": true,
        "allowJs": true,
        "importHelpers": true,
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true,
        "sourceMap": true,
        "isolatedModules": true,
        "paths": {
            "@/*": ["./src/*"]
        },
        "rootDir": ".",
        "outDir": "dist/"
    },
    "include": ["src/"]
}
